{
  "data": {
    "dataset_name": "climbmix",
    "data_dir": "data/climbmix",
    "num_train_shards": 170,
    "tokenizer": "EleutherAI/gpt-neox-20b",
    "sequence_length": 2048,
    "train_buffer_documents": 2048,
    "eval_buffer_documents": 512,
    "tokenizer_batch_size": 128
  },
  "model": {
    "model_name": "ebt",
    "model_size_label": "1b",
    "num_transformer_blocks": 28,
    "multiheaded_attention_heads": 32,
    "embedding_dim": 2048,
    "ebt_type": "time_embed",
    "normalize_initial_condition": true,
    "denoising_initial_condition": "random_noise",

    "mcmc_num_steps": 1,
    "mcmc_step_size": 0.5,
    "mcmc_step_size_learnable": true,
    "mcmc_step_size_lr_multiplier": 1.5,
    "langevin_dynamics_noise": 3.0,
    "randomize_mcmc_step_size_scale": 2.0,
    "randomize_mcmc_num_steps": 3,
    "randomize_mcmc_num_steps_min": 2,

    "mcmc_replay_buffer": true,
    "mcmc_replay_buffer_size": 48,
    "mcmc_replay_buffer_sample_bs_percent": 0.25,
    "truncate_mcmc": true,
    "no_mcmc_detach": true,
    "clamp_futures_grad": true,

    "norm_pred": true,
    "norm_pred_not_final_step": false,
    "scale_alpha_with_energy": true,
    "scale_alpha_with_energy_temp": 1.0
  },
  "optim": {
    "learning_rate": 0.0002,
    "min_lr_fraction": 0.05,
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.95,
    "grad_clip": 1.0,
    "warmup_steps": 10000,
    "warmdown_ratio": 0.65,
    "embedding_lr_scale": 0.5,
    "head_lr_scale": 1.0
  },
  "train": {
    "run_name": "ebt-1b-climbmix",
    "out_dir": "runs/ebt_1b_climbmix",
    "precision": "bf16",
    "compile_model": true,
    "seed": 1337,
    "device_batch_size": 8,
    "gradient_accumulation_steps": 4,
    "target_tokens": 25000000000,
    "max_steps": -1,
    "log_interval": 10,
    "eval_interval": 1000,
    "save_interval": 1000,
    "eval_steps": 64,
    "core_eval_interval": 5000,
    "core_max_per_task": 200,
    "eval_mcmc_depths": [1, 2, 4],
    "humaneval_interval": 5000,
    "humaneval_max_problems": 32,
    "humaneval_max_new_tokens": 256,
    "humaneval_temperature": 0.2,
    "humaneval_top_p": 0.95,
    "humaneval_top_k": 50,
    "humaneval_num_samples": 1,
    "humaneval_self_verify_samples": 1,
    "early_stop_core": 0.257,
    "early_stop_humaneval": 0.0,
    "require_humaneval_for_stop": false,
    "minimum_tokens_before_stop": 8000000000,
    "wandb_project": "energy-coding-pretrain",
    "resume": true
  },
  "post_train": {
    "data_dir": "data/sft",
    "out_dir": "runs/ebt_1b_sft",
    "run_name": "ebt-1b-sft",
    "wandb_project": "energy-coding-sft",
    "max_train_examples": 750000,
    "max_val_examples": 25000,
    "max_test_examples": 25000,
    "max_steps": 20000,
    "learning_rate": 0.00005,
    "warmup_steps": 500,
    "warmdown_ratio": 0.5,
    "device_batch_size": 2,
    "gradient_accumulation_steps": 32,
    "eval_interval": 500,
    "save_interval": 500,
    "eval_steps": 64,
    "precision": "bf16",
    "compile_model": true,
    "resume": true
  }
}
