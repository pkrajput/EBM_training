{
  "data": {
    "data_dir": "data/climbmix_smoke",
    "num_train_shards": 1,
    "sequence_length": 512,
    "train_buffer_documents": 64,
    "eval_buffer_documents": 32,
    "tokenizer_batch_size": 16
  },
  "model": {
    "model_size_label": "smoke",
    "num_transformer_blocks": 2,
    "multiheaded_attention_heads": 4,
    "embedding_dim": 256,
    "mcmc_num_steps": 1,
    "mcmc_step_size": 0.5,
    "mcmc_step_size_learnable": false,
    "mcmc_step_size_lr_multiplier": 1.5,
    "randomize_mcmc_num_steps": 0,
    "randomize_mcmc_num_steps_min": 0,
    "randomize_mcmc_step_size_scale": 1.0,
    "mcmc_replay_buffer": false,
    "langevin_dynamics_noise": 0.0,
    "norm_pred": false,
    "scale_alpha_with_energy": false
  },
  "train": {
    "run_name": "smoke-test",
    "out_dir": "runs/smoke_test",
    "device_batch_size": 1,
    "gradient_accumulation_steps": 1,
    "max_steps": 20,
    "target_tokens": 10240,
    "log_interval": 1,
    "eval_interval": 10,
    "save_interval": 10,
    "eval_steps": 2,
    "core_eval_interval": -1,
    "humaneval_interval": -1,
    "minimum_tokens_before_stop": 1000000000000,
    "compile_model": false,
    "resume": false
  }
}
